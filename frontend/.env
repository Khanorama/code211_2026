# PathFinder — frontend environment variables

# Backend API
VITE_API_URL=http://localhost:8000

# Supabase — real auth and database
# 1. Create a project at https://supabase.com (free tier)
# 2. Go to Project Settings > API
# 3. Copy "Project URL" and "anon public" key below
# 4. Run the SQL in frontend/src/services/supabase.js (lines 10-24) in the Supabase SQL editor
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
